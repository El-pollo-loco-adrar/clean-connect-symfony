{# templates/contact/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contactez le support Clean Connect{% endblock %}

{% block body %}
<div class="flex items-center justify-center h-auto dark:bg-gray-900 py-10 transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border border-black dark:border-gray-700 rounded-2xl p-8">

        <h1 class="text-2xl font-bold text-center text-gray-800">Contactez l'équipe CleanConnect</h1>
        <hr class="border-t-2 border-black my-6 mx-auto w-1/2" />

        <p class="italic text-center text-gray-600 mb-8">Une question ? Un problème technique ? Contactez nous avec ce formulaire.</p>

        {{ form_start(contactForm) }}
            <div class="space-y-4">
                <section>
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                        Nom
                    </label>
                    {{ form_widget(contactForm.name, {
                        'attr': {
                            'class': 'w-full px-4 py-2 rounded-lg border border-black bg-[#3B82F6] bg-opacity-15 dark:border-gray-600 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition'
                        }
                    }) }}
                    <p class="error-message text-red-500 text-xs mt-1 hidden"></p>
                </section>

                <section>
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                        Email
                    </label>
                    {{ form_widget(contactForm.email, {
                        'attr': {
                            'class': 'w-full px-4 py-2 rounded-lg border border-black bg-[#3B82F6] bg-opacity-15 dark:border-gray-600 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition'
                        }
                    }) }}
                    <p class="error-message text-red-500 text-xs mt-1 hidden"></p>
                </section>

                <section>
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                        Sujet
                    </label>
                    {{ form_widget(contactForm.subject, {
                        'attr': {
                            'class': 'w-full px-4 py-2 rounded-lg border border-black bg-[#3B82F6] bg-opacity-15 dark:border-gray-600 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition'
                        }
                    }) }}
                    <p class="error-message text-red-500 text-xs mt-1 hidden"></p>
                </section>

                <section>
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                        Votre message
                    </label>
                    {{ form_widget(contactForm.message, {
                        'attr': {
                            'class': 'w-full px-4 py-2 rounded-lg border border-black bg-[#3B82F6] bg-opacity-15 dark:border-gray-600 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition'
                        }
                    }) }}
                    <p class="error-message text-red-500 text-xs mt-1 hidden"></p>
                </section>

                <button type="submit" 
                    class="w-full bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-bold py-3 rounded-lg shadow-lg dark:shadow-blue-900/20 transform transition hover:scale-[1.02] active:scale-95">
                Envoyer le message
                </button>
            </div>
        {{ form_end(contactForm) }}

        {# {{ form_start(contactForm) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {{ form_row(contactForm.name) }}
                {{ form_row(contactForm.email) }}
            </div>
            <div class="mt-4">
                {{ form_row(contactForm.subject) }}
            </div>
            <div class="mt-4">
                {{ form_row(contactForm.message) }}
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-bold py-3 rounded-lg shadow-lg dark:shadow-blue-900/20 transform transition hover:scale-[1.02] active:scale-95">
                Envoyer le message
            </button>
        {{ form_end(contactForm) }} #}
    </div>
</div>
{% endblock %}