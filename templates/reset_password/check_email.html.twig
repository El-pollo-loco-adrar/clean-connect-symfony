{% extends 'base.html.twig' %}

{% block title %}Email envoyé{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[60vh] dark:bg-gray-900 py-10 transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border-2 border-black dark:border-gray-700 rounded-2xl p-8 text-center">
        
        <div class="mb-6 inline-flex items-center justify-center w-16 h-16 bg-green-100 border-2 border-black rounded-full">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002 -2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
        </div>

        <h1 class="text-2xl font-bold text-gray-800 uppercase mb-4">Vérifiez vos mails</h1>
        
        <p class="text-gray-600 mb-6 leading-relaxed">
            Si un compte correspond à votre adresse, un email vient d'être envoyé. 
            Il contient un lien sécurisé pour réinitialiser votre mot de passe.
        </p>

        <div class="bg-blue-50 border-2 border-[#2563EBCC] p-4 rounded-lg mb-6 text-sm text-blue-800">
            Ce lien expirera dans <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
        </div>

        <p class="text-xs text-gray-500 mb-6">
            Vous ne trouvez pas le mail ? Pensez à vérifier vos <strong>courriers indésirables (spams)</strong>.
        </p>

        <hr class="border-t border-gray-300 mb-6">

        <a href="{{ path('app_forgot_password_request') }}" class="text-sm font-bold text-[#2563EBCC] hover:underline uppercase tracking-tighter">
            Réessayer avec une autre adresse
        </a>
    </div>
</div>
{% endblock %}