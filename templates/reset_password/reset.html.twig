{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block body %}
<div class="flex items-center justify-center h-auto dark:bg-gray-900 py-10 transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border border-black dark:border-gray-700 rounded-2xl p-8">
        
        <h1 class="text-2xl font-bold text-center text-gray-800">Nouveau mot de passe</h1>
        <p class="text-sm text-center text-gray-500 dark:text-gray-400 mb-8">
            Choisissez un mot de passe robuste pour sécuriser votre compte.
        </p>
        <hr class="border-t-2 border-black my-6 mx-auto w-1/2" />

        {{ form_start(resetForm) }}
            <div class="space-y-6">
                {# On personnalise l'affichage du champ de mot de passe #}
                {% for passwordField in resetForm.plainPassword %}
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-300">
                            {{ passwordField.vars.label|trans }}
                        </label>
                        {{ form_widget(passwordField, {
                            'attr': {
                                'class': 'w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all',
                                'placeholder': '••••••••'
                            }
                        }) }}
                        {{ form_errors(passwordField) }}
                    </div>
                {% endfor %}
            </div>

            <div class="mt-8">
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-colors duration-200">
                    Mettre à jour le mot de passe
                </button>
            </div>
        {{ form_end(resetForm) }}
    </div>
</div>
{% endblock %}