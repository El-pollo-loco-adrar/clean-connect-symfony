{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="flex items-center justify-center h-auto dark:bg-gray-900 py-10 transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border-2 border-black dark:border-gray-700 rounded-2xl p-8">
        
        <h1 class="text-2xl font-bold text-center text-gray-800 uppercase tracking-wider">Récupération</h1>
        <hr class="border-t-2 border-black my-6 mx-auto w-1/2" />

        <p class="text-sm text-gray-600 mb-6 text-center">
            Saisissez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
        </p>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
                {{ flash_error }}
            </div>
        {% endfor %}

        {{ form_start(requestForm) }}
            <div class="mb-6">
                <label for="{{ requestForm.email.vars.id }}" class="block mb-2 text-sm font-bold text-gray-700 uppercase">
                    Votre adresse mail
                </label>
                {{ form_widget(requestForm.email, {
                    'attr': {
                        'class': 'w-full px-4 py-3 border border-black rounded-[4px] focus:ring-0 focus:border-[#2563EBCC] outline-none transition-all',
                        'placeholder': 'ex: jean.dupont@mail.com'
                    }
                }) }}
                {{ form_errors(requestForm.email) }}
            </div>

            <div class="flex flex-col items-center gap-4">
                <button type="submit" class="bg-[#2563EBCC] w-full px-6 py-3 text-white border-2 border-black rounded-[4px] font-bold hover:translate-y-1 hover:shadow-none transition-all uppercase tracking-tighter">
                    Envoyer le lien
                </button>
                
                <a href="{{ path('app_login') }}" class="text-sm font-bold text-gray-600 hover:text-black transition-colors underline">
                    Retour à la connexion
                </a>
            </div>
        {{ form_end(requestForm) }}
    </div>
</div>
{% endblock %}