{# Le candidat et l'employeur peuvent modifier leurs informations personnelles #}
{% extends 'base.html.twig' %}

{% block title %}Modifier mes informations{% endblock %}

{% block body %}
<div class="flex items-center justify-center h-auto dark:bg-gray-900 py-10 transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border border-black dark:border-gray-700 rounded-2xl p-8">
        
        <h1 class="text-2xl font-bold text-center text-gray-800">Modifier mes informations</h1>
        <hr class="border-t-2 border-black my-6 mx-auto w-1/2" />

        <p class="text-xs text-center italic mb-4">Toutes les informations ci-dessous sont obligatoires pour pouvoir utiliser les fonctionnalités de <span class="font-bold">Clean Connect</span>.</p>
        {{ form_start(form) }}
            <div class="space-y-4">
                <section>
                {# --- NOM --- #}
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                    Nom
                    </label>
                    {{ form_widget(form.lastname, {
                        'attr': {
                            'class': 'w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm focus:ring-blue-500'
                        }
                    }) }}
                    <p class="error-message text-red-500 text-xs mt-1 hidden"></p>
                </section>

                <section>
                {# --- PRENOM --- #}
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                    Prénom
                    </label>
                    {{ form_widget(form.firstname, {
                        'attr': {
                            'class': 'w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm focus:ring-blue-500'
                        }
                    }) }}
                </section>

                <section>
                {# --- NUMERO DE TEL --- #}
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                    Numéro de téléphone
                    </label>
                    {{ form_widget(form.phoneNumber, {
                        'attr': {
                            'class': 'w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm focus:ring-blue-500'
                        }
                    }) }}
                </section>
            

                {# --- NOM DE LA SOCIETE COTE EMPLOYER UNIQUEMENT --- #}
                {% if form.companyName is defined %}
                <section>
                    <label class="flex items-center justify-center gap-2 w-full font-semibold text-gray-700 mb-2 dark:text-white-200">
                    Nom de ma société
                    </label>
                    {{ form_widget(form.companyName, {
                        'attr': {
                            'class': 'w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm focus:ring-blue-500'
                        }
                    }) }}
                </section>
                {% endif %}

                {# Bouton submit #}
                <div class="mt-8 flex flex-col items-center gap-4">
                    <button type="submit" class="bg-[#2563EBCC] w-fit px-6 py-3 text-white border-2 border-black rounded-[4px] font-bold shadow-lg hover:scale-105 transition-transform">
                        Enregistrer
                    </button>

                    {# 1. On prépare les données selon le type d'utilisateur #}
                    {% set targetPath = path('app_home') %}
                    {% set label = 'Annuler' %}

                    {% if app.user and app.user.userType == 'candidate' %}
                        {% set targetPath = path('app_candidate_profile_dashboard') %}
                        {% set label = 'Annuler et revenir en arrière' %}
                    {% endif %}

                    {# 2. On affiche un seul bouton propre #}
                    <a href="{{ targetPath }}" 
                    class="bg-red-500 w-fit px-4 py-1.5 text-sm text-white border-2 border-black rounded-[4px] font-bold shadow-lg hover:scale-105 transition-transform inline-block">
                        {{ label }}
                    </a>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {# public/js #}
    <script src="{{ asset('js/profile-validation.js') }}"></script>
    <script>
        // initialise les ID de symfony
        initProfileValidation({
            lastnameId: "{{ form.lastname.vars.id }}",
            firstnameId: "{{ form.firstname.vars.id }}",
            phoneId: "{{ form.phoneNumber.vars.id }}",
            companyNameId: "{{ form.companyName is defined ? form.companyName.vars.id : null }}",
        });
    </script>
{% endblock %}
