{# 1. On prépare les variables logiques #}
{% set isLink = routeName is defined and routeName is not null %}
{% set tag = isLink ? 'a' : 'div' %}

{# 2. La balise s'adapte dynamiquement #}
<{{ tag }} 
    {% if isLink %}href="{{ path(routeName) }}"{% endif %} 
    class="border-2 border-black bg-[#3B82F6] bg-opacity-15 text-center rounded-xl shadow-lg flex flex-col items-center justify-center p-4 min-h-[140px] gap-2 dark:border-gray-600 dark:bg-gray-700 transition-all {{ isLink ? 'transition-transform active:scale-95 hover:translate-y-1 hover:shadow-none' : '' }} {{ extra_classes|default('') }}"
>
    
    <div class="flex flex-col items-center gap-2">
        <div>
            {% block icon %}{% endblock %}
        </div>
        
        <span class="font-bold text-sm leading-tight px-2 text-gray-800 dark:text-gray-100">
            {{ label }}
        </span>
    </div>

</{{ tag }}>