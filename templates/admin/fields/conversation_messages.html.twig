<div class="message-history" style="max-height: 500px; overflow-y: auto; padding: 10px; background: #f9f9f9; border-radius: 8px;">
    {% for message in field.value %}
        <div style="margin-bottom: 15px; padding: 10px; border-radius: 10px; border: 1px solid #ddd; {{ app.user == message.author ? 'background: #e3f2fd; margin-left: 20px;' : 'background: #fff; margin-right: 20px;' }}">
            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <strong>{{ message.author.firstname }} {{ message.author.lastname }}</strong>
                <small class="text-muted">{{ message.createdAt|date('d/m/Y H:i') }}</small>
            </div>
            <div class="message-content">
                {{ message.content|raw }}
            </div>
            {% if message.isRead %}
                <div style="text-align: right;"><small>✔ Lu</small></div>
            {% endif %}
        </div>
    {% else %}
        <p class="text-muted">Aucun message dans cette conversation.</p>
    {% endfor %}
</div>