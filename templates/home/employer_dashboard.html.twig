{# Page home de l'employeur #}
{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="flex pt-12 justify-center h-auto dark:bg-gray-900  transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border border-black dark:border-gray-700 rounded-2xl p-8">

        <div class="mt-8 flex flex-col items-center">
            <h1 class="text-2xl font-bold text-center text-gray-800">Bienvenue</h1>
            <span class="text-center text-gray-800">{{ app.user.firstname}} {{ app.user.lastname }}</span>
        </div>

        <div class="grid grid-cols1 min-[398px]:grid-cols-2 gap-6 m-12">

        {# J'utilise le composant dashboard_card pour faire les cards carrés
        /components/_dashboard_card.html.twig#}

            {# Créer mission #}
            {% embed "components/_dashboard_card.html.twig" with { 
                'routeName': 'app_mission_create',
                'label': 'Créer une mission'} 
            %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                    </svg>
                {% endblock %}
            {% endembed %}

            {# Mes missions #}
            {% embed "components/_dashboard_card.html.twig" with { 'routeName': 'app_show_mission', 'label': 'Mes missions'} %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-10">
                        <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15ZM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146Z" />
                    </svg>
                {% endblock %}
            {% endembed %}

            {# CANDIDATURES ET MESSAGERIE #}
            {% embed "components/_dashboard_card.html.twig" with { 'routeName': 'app_employer_conversations', 'label': 'Candidatures & Messagerie'} %}
                {% block icon %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                    </svg>
                {% endblock %}    
            {% endembed %}

            {% embed "components/_dashboard_card.html.twig" with { 'routeName': 'app_profile_complete', 'label': 'Modifier mes informations'} %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                    </svg>
                {% endblock %}
            {% endembed %}

            {% embed "components/_dashboard_card.html.twig" with { 'routeName': 'app_profile_complete', 'label': 'Mes achats'} %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                {% endblock %}
            {% endembed %}

            {% embed "components/_dashboard_card.html.twig" with { 'routeName': 'app_profile_complete', 'label': 'Contacter le support'} %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                    </svg>
                {% endblock %}
            {% endembed %}

        </div>

    </div>
</div>
{% endblock %}
