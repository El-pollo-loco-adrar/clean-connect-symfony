{% extends 'base.html.twig' %}
{# DASHBOARD PROFIL DU CANDIDAT #}
{% block title %}Mon espace profil{% endblock %}

{% block body %}
<div class="flex pt-12 justify-center h-auto dark:bg-gray-900  transition-colors">
    <div class="w-full max-w-md mx-4 bg-[#F3F4F6] shadow-xl border border-black dark:border-gray-700 rounded-2xl p-8">
        
        <h1 class="text-xl md:text-2xl font-bold text-center text-gray-800">Mon espace profil</h1>
        <hr class="border-t-2 border-black my-6 mx-auto w-1/2" />
        <p class="text-center text-gray-500 mb-10 font-medium">Gérez et modifier vos informations.</p>

        {# Grille des 4 liens #}
        <div class="grid grid-cols1 min-[398px]:grid-cols-2 gap-6 m-12">
            
            {# 1. INFOS PERSONNELLES #}
            {% embed "components/_dashboard_card.html.twig" with { 
                'routeName': 'app_profile_complete',
                'label': 'Identité'} 
            %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                {% endblock %}
            {% endembed %}
                    

            {# 2. COMPÉTENCES #}
            {% embed "components/_dashboard_card.html.twig" with { 
                'routeName': 'app_skills_candidate',
                'label': 'Compétences'} 
            %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                {% endblock %}
            {% endembed %}

            {# 3. ZONE DE DÉPLACEMENT #}
            {% embed "components/_dashboard_card.html.twig" with { 
                'routeName': 'app_candidate_areas',
                'label': 'Zones de déplacement'} 
            %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                {% endblock %}                        
            {% endembed %}

            {# 4. DISPONIBILITÉS #}
            {% embed "components/_dashboard_card.html.twig" with { 
                'routeName': 'app_availability',
                'label': 'Disponibilités'} 
            %}
                {% block icon %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                {% endblock %}
            {% endembed %}

        </div>
    </div>
</div>
{% endblock %}